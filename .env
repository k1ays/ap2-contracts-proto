# Database
ORDER_DB_DSN=postgres://postgres:postgres@order-db:5432/order_db?sslmode=disable
PAYMENT_DB_DSN=postgres://postgres:postgres@payment-db:5432/payment_db?sslmode=disable

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Redis
REDIS_ADDR=redis:6379

# Order Service
ORDER_ADDR=:8080
ORDER_GRPC_ADDR=:9090
PAYMENT_GRPC_ADDR=payment-service:50051

# Cache
CACHE_TTL=300

# Rate Limiter
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# Notification Provider
PROVIDER_MODE=SIMULATED

# Retry Policy
MAX_RETRIES=5
INITIAL_BACKOFF=2

# Notification worker pool (parallel message processing)
WORKER_COUNT=5
